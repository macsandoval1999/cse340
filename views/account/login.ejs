<%# Scripts specific to the login page. This variable will be included in the head partial, allowing us to include page-specific scripts when needed. %>
<% pageScripts = '<script src="/js/login.js" type="module"></script>' %>

<%# The Content Heading %>
<% if (title) { %>
    <h1 class="accountTitle">
        <%= title %>
    </h1>
<% } else { res.redirect('/') } %>

<%# Flash Messages %>
<%# If there are messages, meaning the array returned by messages() is not empty, display them.%>
<div class="flashBox"><%- messages() %></div>

<form action="/account/login" method="POST" class="account-form">
    <fieldset>
        <legend>Login to continue</legend>

        <label for="email">Email
            <input type="email" id="email" name="account_email" required autocomplete="email" title="Your Email Address">
        </label>

        <label for="password" class="passwordBox">Password
            <input type="password" id="password" name="account_password" title="Your Password" required>
            <span id="pswdBtn" class="toggle-password"><i id="pswdIcon" class="fa-solid fa-eye"></i></span>
        </label>
      

        <button type="submit">Continue</button>
    </fieldset>

    <div class="register-link">
        <p>Don't have an account? <a href="/account/register">Register here</a>.</p>
    </div>

</form>






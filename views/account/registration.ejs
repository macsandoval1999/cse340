<%# The Content Heading %>
<% if (title) { %>
    <h1 class="accountTitle">
        <%= title %>
    </h1>
<% } else { res.redirect('/') } %>


<%# Flash Messages %>
<%- messages() %>
<% if (errors) { %>
    <ul class="notice flashBox">
        <% errors.array().forEach(error => { %>
            <% if (error.msg !== 'Invalid value') { %>
                <li><%= error.msg %></li>
            <% } %>
        <% }) %>
    </ul>
<% } %>

<form action="/account/registration" method="POST" class="account-form">
    <fieldset>
        <legend>Create Your Account</legend>

         <!-- The ejs snippets in the these three input fields are used to retain the user's input in case of validation errors. We take the value from the locals object, which is populated with the user's input if there are validation errors. This ensures that the user's input is not lost and they don't have to re-enter it. Never do this for passwords for security reasons. -->
        <label for="firstName">First Name
            <input type="text" id="firstName" name="account_firstname" required autocomplete="given-name" title="Your First Name" value="<%= locals.account_firstname %>">
        </label>

        <label for="lastName">Last Name
            <input type="text" id="lastName" name="account_lastname" required autocomplete="family-name" title="Your Last Name " value="<%= locals.account_lastname %>">
        </label>

        <label for="email">Email
            <input type="email" id="email" name="account_email" required autocomplete="email" title="Your Email Address" value="<%= locals.account_email %>">
        </label>

        <label for="password" class="passwordBox">Password
            <input type="password" id="password" name="account_password" pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$" title="Password must be at least 12 characters, include an uppercase letter, a number, and a special character.">
            <span id="pswdBtn" class="toggle-password"><i id="pswdIcon" class="fa-solid fa-eye"></i></span>            
        </label>

        
        <div class="password-requirements">
            <p>Password must be at least 12 characters long and include:</p>
            <ul>
                <li>At least one uppercase letter</li>
                <li>At least one number</li>
                <li>At least one special character</li>
            </ul>
        </div>

        <button type="submit">Register</button>
    </fieldset>

    <div class="register-link">
        <p>Already have an account? <a href="/account/login">Login here</a>.</p>
    </div>
</form>

<script src="../../js/passwordToggle.js" type="module"></script>
